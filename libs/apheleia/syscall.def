#ifndef SYSCALL
#error "define SYSCALL before including syscall.def"
#endif

SYSCALL(EXIT, exit, 0)
SYSCALL(READ, read, 1)
SYSCALL(WRITE, write, 2)
SYSCALL(OPEN, open, 3)
SYSCALL(CLOSE, close, 4)
SYSCALL(PIPE, pipe, 5)
SYSCALL(DUP, dup, 6)
SYSCALL(FCNTL, fcntl, 7)
SYSCALL(PREAD, pread, 8)
SYSCALL(PWRITE, pwrite, 9)
SYSCALL(LSEEK, lseek, 10)
SYSCALL(IOCTL, ioctl, 11)
SYSCALL(POLL, poll, 12)
SYSCALL(CHDIR, chdir, 13)
SYSCALL(MKDIR, mkdir, 14)
SYSCALL(RMDIR, rmdir, 15)
SYSCALL(GETDENTS, getdents, 16)
SYSCALL(ACCESS, access, 17)
SYSCALL(STAT, stat, 18)
SYSCALL(LSTAT, lstat, 19)
SYSCALL(FSTAT, fstat, 20)
SYSCALL(TRUNCATE, truncate, 21)
SYSCALL(FTRUNCATE, ftruncate, 22)
SYSCALL(CHMOD, chmod, 23)
SYSCALL(CHOWN, chown, 24)
SYSCALL(LINK, link, 25)
SYSCALL(SYMLINK, symlink, 26)
SYSCALL(READLINK, readlink, 27)
SYSCALL(UNLINK, unlink, 28)
SYSCALL(RENAME, rename, 29)
SYSCALL(MOUNT, mount, 30)
SYSCALL(UMOUNT, umount, 31)
SYSCALL(MMAP, mmap, 32)
SYSCALL(MPROTECT, mprotect, 33)
SYSCALL(MUNMAP, munmap, 34)
SYSCALL(FORK, fork, 35)
SYSCALL(EXECVE, execve, 36)
SYSCALL(WAITPID, waitpid, 37)
SYSCALL(SLEEP, sleep, 38)
SYSCALL(SIGNAL, signal, 39)
SYSCALL(SIGRETURN, sigreturn, 40)
SYSCALL(KILL, kill, 41)
SYSCALL(TIME, time, 42)
